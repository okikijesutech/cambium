# Copy this file to .env and fill in what you need.
# .env is optional — you can also use `export` in your terminal instead.

# Only needed if you want to use Claude via the Anthropic API instead of Ollama.
# ANTHROPIC_API_KEY=sk-ant-...

# Force a specific provider. If unset, Cambium uses Ollama automatically
# when ANTHROPIC_API_KEY is not set, and Anthropic when it is.
# LLM_PROVIDER=ollama

# Only needed if Ollama isn't reachable at the default http://127.0.0.1:11434
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Only needed if you've pulled a different model name than qwen2.5-coder:latest
# OLLAMA_MODEL=qwen2.5-coder:latest
