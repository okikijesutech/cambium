    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["typescript", "static-analysis", "refactoring", "ai-tools", "code-quality", "cli"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "commander": "^15.0.0",
    "ts-morph": "^28.0.0",
